---
import { site, nav } from "@data/site";
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<div class="consortium-strip">
  <div class="container row">
    <a class="consortium-link" href={site.consortium.url} rel="noopener">
      <span class="dot" aria-hidden="true"></span>
      <span>A service of the <strong>{site.consortium.name}</strong></span>
    </a>
    <a class="consortium-cta" href={site.consortium.parentUrl} rel="noopener">
      Visit {site.consortium.parentName} →
    </a>
  </div>
</div>
<header class="site-header">
  <div class="container row">
    <a class="brand" href="/" aria-label={`${site.name} home`}>
      <span class="brand-mark" aria-hidden="true">c</span>
      <span class="brand-text">crimux</span>
    </a>
    <nav aria-label="Primary">
      <ul class="navlist">
        {nav.map((item) => {
          const active = pathname === item.href || pathname.startsWith(item.href + "/");
          return (
            <li>
              <a href={item.href} aria-current={active ? "page" : undefined}>{item.label}</a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .consortium-strip {
    background: var(--ink);
    color: var(--paper);
    font-size: 0.82rem;
  }
  .consortium-strip .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-3);
    padding-block: 0.4rem;
    flex-wrap: wrap;
  }
  .consortium-link,
  .consortium-cta {
    color: var(--paper);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .consortium-link strong { font-weight: 600; }
  .consortium-link:hover,
  .consortium-cta:hover { color: var(--brand); }
  .consortium-link .dot {
    width: 8px; height: 8px; border-radius: 999px;
    background: var(--brand);
    display: inline-block;
  }
  .consortium-cta { font-weight: 500; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--rule);
  }
  .row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-5);
    padding-block: var(--s-3);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--s-2);
    text-decoration: none;
    color: var(--ink);
    font-weight: 700;
  }
  .brand-mark {
    width: 28px;
    height: 28px;
    display: inline-grid;
    place-items: center;
    background: var(--brand);
    color: var(--ink);
    font-family: var(--font-display);
    font-weight: 700;
    border-radius: 8px;
    line-height: 1;
  }
  .brand-text {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: -0.01em;
  }
  .navlist {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-4);
    align-items: baseline;
  }
  .navlist li {
    display: inline-block;
    margin: 0;
    padding: 0;
  }
  /* Every nav link is rendered identically. The ONLY visual difference
     between active and inactive is the underline color. Text color,
     weight, size, line-height, and padding are locked so baselines and
     letterforms match across all items, in light and dark mode, on any
     page. */
  .navlist a {
    text-decoration: none;
    color: var(--ink-2);
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.2;
    padding: 0.3rem 0.1rem;
    border-bottom: 2px solid transparent;
    display: inline-block;
    white-space: nowrap;
    vertical-align: baseline;
  }
  .navlist a:hover { color: var(--brand); border-bottom-color: var(--brand-soft); }
  .navlist a[aria-current="page"] {
    /* Keep the same color and weight as inactive items so nothing shifts
       or looks bolder; the orange underline is what marks the page. */
    color: var(--ink-2);
    border-bottom-color: var(--brand);
  }
  @media (max-width: 720px) {
    .row { flex-direction: column; align-items: stretch; gap: var(--s-3); }
    .brand { align-self: flex-start; }
    /* Single-row, edge-to-edge horizontal scroll on phones so every item
       sits on one baseline, regardless of active state. */
    nav[aria-label="Primary"] {
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    nav[aria-label="Primary"]::-webkit-scrollbar { display: none; }
    .navlist {
      flex-wrap: nowrap;
      font-size: 0.95rem;
      gap: var(--s-4);
      padding-bottom: 2px;
    }
    .consortium-strip .row {
      flex-direction: row;
      align-items: center;
      padding-block: 0.45rem;
      gap: var(--s-3);
      font-size: 0.78rem;
    }
    .consortium-link { flex: 1 1 auto; min-width: 0; }
    .consortium-cta { flex: 0 0 auto; white-space: nowrap; }
  }
</style>
