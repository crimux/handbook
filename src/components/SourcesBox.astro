---
interface SourceItem {
  text: string;
  href?: string;
}
interface Props {
  title?: string;
  items: SourceItem[];
}
const { title = "Sources & Further Reading", items } = Astro.props;
---
<aside class="sources">
  <p class="label">{title}</p>
  <ol>
    {items.map((it) => (
      <li>
        {it.href ? <a href={it.href} rel="noopener">{it.text}</a> : <span>{it.text}</span>}
      </li>
    ))}
  </ol>
</aside>

<style>
  .sources {
    background: var(--paper-2);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    padding: var(--s-5);
    margin: var(--s-6) 0;
  }
  .label {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--indigo);
    margin: 0 0 var(--s-3);
  }
  ol { margin: 0; padding-left: 1.2rem; font-size: 0.92rem; color: var(--ink-2); }
  li + li { margin-top: var(--s-2); }
</style>
