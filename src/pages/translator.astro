---
import Base from "@layouts/Base.astro";
import translator from "@data/translator.json";
---
<Base title="Skills Translator" description="Browse common translations from criminology research methods into UX research framing, or type your own to get a sharable card.">
  <header class="container hero">
    <p class="eyebrow">Skills translator</p>
    <h1>From criminology to user-experience framing</h1>
    <p class="lead">Browse the {translator.mappings.length} common translations below, or type your own method, skill, or experience to get a custom translation and a sharable card.</p>
  </header>

  <section class="container">
    <form id="t-form" class="t-form">
      <label for="t-input">Your skill or experience</label>
      <textarea id="t-input" rows="3" placeholder="e.g., I ran a 14-month ethnography of drug markets with 35 interviews and field observation."></textarea>
      <button type="submit" class="btn">Translate</button>
    </form>

    <section id="t-result" hidden>
      <h2 id="t-uxr">—</h2>
      <p id="t-frame" class="lead">—</p>
      <p class="muted small">Matched on: <span id="t-match">—</span></p>

      <div class="cluster">
        <button id="t-copy" class="btn-ghost" type="button">Copy result</button>
        <a id="t-share" class="btn" target="_blank" rel="noopener">Share on LinkedIn</a>
      </div>

      <details>
        <summary>Card preview</summary>
        <div id="t-card" class="share-card"></div>
      </details>
    </section>
  </section>

  <section class="container catalog-section">
    <h2>Common translations</h2>
    <p>Each row maps a criminology research method or experience to its closest UX research analog, with a one-paragraph frame you can adapt for a resume, application, or interview answer.</p>
    <ol class="catalog">
      {translator.mappings.map((m: any, i: number) => {
        const ACRONYMS = new Set(["irb", "spss"]);
        const raw = (m.label || m.match[0]).trim();
        const display = ACRONYMS.has(raw.toLowerCase())
          ? raw.toUpperCase()
          : raw.charAt(0).toUpperCase() + raw.slice(1);
        return (
        <li class="row" id={`m-${i + 1}`}>
          <div class="row-head">
            <p class="src">{display}</p>
            <p class="arrow" aria-hidden="true">→</p>
            <p class="dst">{m.uxr}</p>
          </div>
          <p class="frame">{m.frame}</p>
          {m.match.length > 1 && (
            <p class="aka muted small">Also matches: {m.match.slice(1).map((s: string) => s.trim()).join(", ")}</p>
          )}
        </li>
        );
      })}
    </ol>
  </section>
</Base>

<script define:vars={{ translator }}>
  const form = document.getElementById("t-form");
  const input = document.getElementById("t-input");
  const result = document.getElementById("t-result");
  const uxrEl = document.getElementById("t-uxr");
  const frameEl = document.getElementById("t-frame");
  const matchEl = document.getElementById("t-match");
  const copyBtn = document.getElementById("t-copy");
  const shareBtn = document.getElementById("t-share");
  const card = document.getElementById("t-card");

  function translate(text) {
    const q = (text || "").toLowerCase();
    for (const m of translator.mappings) {
      for (const k of m.match) {
        if (q.includes(k)) return { ...m, matched: k };
      }
    }
    return { ...translator.fallback, matched: "(no exact match — generic frame)" };
  }

  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const out = translate(input.value);
    uxrEl.textContent = out.uxr;
    frameEl.textContent = out.frame;
    matchEl.textContent = out.matched;

    const text = `Criminology → UX research translation: "${(input.value || "").slice(0, 120)}" → ${out.uxr}. crimux.com/translator`;
    shareBtn.href = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent("https://crimux.com/translator")}`;
    copyBtn.onclick = async () => {
      try { await navigator.clipboard.writeText(text); copyBtn.textContent = "Copied"; setTimeout(() => copyBtn.textContent = "Copy result", 1500); } catch {}
    };

    card.innerHTML = `
      <div class="sc-inner">
        <p class="sc-eyebrow">Skills Translator · crimux.com</p>
        <p class="sc-source">${(input.value || "").slice(0, 120)}</p>
        <p class="sc-arrow">→</p>
        <p class="sc-uxr">${out.uxr}</p>
      </div>
    `;

    result.hidden = false;
    result.scrollIntoView({ behavior: "smooth" });
  });
</script>

<style>
  .hero { padding-block: var(--s-8) var(--s-5); }
  .t-form { display: grid; gap: var(--s-3); max-width: 640px; margin-bottom: var(--s-6); }
  .catalog-section { padding-top: var(--s-7); border-top: 1px solid var(--rule); margin-top: var(--s-6); }
  .catalog { list-style: none; padding: 0; margin: var(--s-5) 0 0; display: grid; gap: var(--s-4); counter-reset: row; }
  .row {
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: var(--radius-lg);
    padding: var(--s-5);
  }
  .row-head {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    gap: var(--s-3);
    margin: 0 0 var(--s-3);
  }
  .row .src, .row .dst {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    margin: 0;
    color: var(--ink);
  }
  .row .dst { color: var(--brand); }
  .row .arrow {
    margin: 0;
    color: var(--ink-3);
    font-family: var(--font-display);
    font-size: 1.2rem;
  }
  .row .frame { margin: 0; color: var(--ink-2); }
  .row .aka { margin: var(--s-2) 0 0; }
  @media (max-width: 640px) {
    .row-head { grid-template-columns: 1fr; gap: 0.35rem; }
    .row .arrow { display: none; }
  }
  .t-form label { font-weight: 600; }
  textarea {
    font: inherit;
    padding: var(--s-3);
    border-radius: var(--radius);
    border: 1px solid var(--rule);
    background: var(--paper);
    color: var(--ink);
    resize: vertical;
  }
  .btn, .btn-ghost { font: inherit; padding: 0.7rem 1.2rem; border-radius: var(--radius); border: 1px solid transparent; cursor: pointer; text-decoration: none; }
  .btn { background: var(--brand); color: var(--ink); display: inline-block; font-weight: 600; }
  .btn:hover { background: var(--brand-2); color: #fff; }
  .btn-ghost { background: var(--paper); color: var(--ink); border-color: var(--rule); }
  #t-result { padding: var(--s-6) 0; border-top: 1px solid var(--rule); }
  .share-card {
    margin-top: var(--s-3);
    aspect-ratio: 1200 / 630;
    background: linear-gradient(135deg, var(--brand), var(--ink));
    color: #fff;
    border-radius: var(--radius-lg);
    padding: var(--s-6);
    display: grid;
    place-content: center;
    text-align: center;
  }
  .sc-eyebrow { text-transform: uppercase; letter-spacing: 0.12em; font-size: 0.78rem; opacity: 0.85; margin: 0 0 var(--s-3); color: #fff; }
  .sc-source { font-size: 1rem; opacity: 0.9; margin: 0; max-width: 32ch; margin-inline: auto; color: #fff; }
  .sc-arrow { font-family: var(--font-display); font-size: 2rem; margin: var(--s-3) 0; opacity: 0.7; color: #fff; }
  .sc-uxr { font-family: var(--font-display); font-size: clamp(1.6rem, 3.5vw, 2.4rem); color: #fff; margin: 0; font-weight: 600; }
  .small { font-size: 0.85rem; }
</style>
